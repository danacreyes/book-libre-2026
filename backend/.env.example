# ─────────────────────────────────────────────────────────────────────────────
# PLANTILLA de variables de entorno (SIN secrets). Este archivo SÍ se commitea
# y documenta qué variables necesita la app. Copialo a `.env` y completá valores.
#
# Spring Boot las consume vía los placeholders ${VAR} de application.yml
# (o por relaxed binding: SPRING_DATASOURCE_URL, etc.).
# ─────────────────────────────────────────────────────────────────────────────

# --- PostgreSQL ---
# Local (docker-compose): jdbc:postgresql://localhost:5433/booklibre
# Render: jdbc:postgresql://<host>:5432/<db>  (formato JDBC, NO el postgres://)
#   Conexión externa a Render exige SSL: agregar ?sslmode=require al final de DB_URL.
DB_URL=jdbc:postgresql://<host>:<port>/<db>
DB_USERNAME=<usuario>
DB_PASSWORD=<password>
# Estrategia de esquema de Hibernate. Local: create-drop. En Render: update.
JPA_DDL_AUTO=update

# --- MongoDB ---
# Local (docker-compose): mongodb://admin:admin@127.0.0.1:27019/book_libre?authSource=admin
# Atlas M0: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
MONGODB_URI=<connection-string>

# --- Redis / Valkey ---
# Local: host=localhost port=6379 (sin password)
# Render Key Value: host/puerto/password que provee el servicio
REDIS_HOST=<host>
REDIS_PORT=<port>
REDIS_PASSWORD=<password-o-vacio-en-local>

# --- JWT ---
# Clave para firmar tokens (HS256 → mínimo 32 caracteres). NUNCA commitear la real.
JWT_KEY=<clave-secreta-min-32-chars>

# --- Server ---
# Render inyecta PORT automáticamente. En local no hace falta (default 8080).
PORT=8080

# --- CORS ---
# Orígenes permitidos (separados por coma). Local: Vite dev. En la nube, la URL del front.
# Ej Render: https://frontend-2026-grupo2.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost:5173
